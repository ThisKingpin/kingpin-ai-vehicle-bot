# ── Discord (zorunlu) ─────────────────────────────────────────────────────────
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
GUILD_ID=

# ── AI (en az biri zorunlu; Gemini birincil) ────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=

# ── FiveM köprüsü (zorunlu) ─────────────────────────────────────────────────
# FiveM server.cfg ai_vehicle_secret ile AYNI olmali
AI_VEHICLE_SECRET=

# ── Sunucu / Discord ayarlari ─────────────────────────────────────────────────
SERVER_NAME=Kingpin RP
LOG_CHANNEL_ID=
ADMIN_ROLE_ID=
FORUM_CHANNEL_ID=

# ── STAGE — Karakter Hikayesi Sistemi ───────────────────────────────────────
# FiveM resource bunları KULLANMAZ — yalnızca Discord bot (Node.js) için.
# FiveM zaten server.cfg mysql_connection_string + oxmysql kullanır.
#
# Railway'de bot + MySQL FiveM VDS'te ise:
#   STAGE_DB_HOST = sunucunun PUBLIC IP veya tunnel hostname (127.0.0.1 OLMAZ)
# Bot FiveM ile aynı makinedeyse:
#   STAGE_DB_HOST=127.0.0.1

# STAGE_DB_HOST=185.xxx.xxx.xxx
# STAGE_DB_PORT=3306
# STAGE_DB_USER=stage_bot
# STAGE_DB_PASS=
# STAGE_DB_NAME=QBCore_3C4418

# Discord'daki "karakterler" forum kanalının ID'si
# STAGE_FORUM_CHANNEL_ID=

# ── Opsiyonel ─────────────────────────────────────────────────────────────────
# Forum hikaye karakter limiti (varsayilan 20000)
# STORY_MAX=20000

# Pull modu: FIVEM_BASE_URL artik GEREKLI DEGIL
# FiveM server.cfg: set ai_vehicle_bot_url "https://xxx.railway.app"

# Embed arac gorseli (varsayilan: https://docs.fivem.net/vehicles)
# VEHICLE_IMAGE_BASE_URL=

# Gemini ile gorsel yeniden siralama (false/0 kapatir)
# VEHICLE_VISUAL_ANALYSIS=true
