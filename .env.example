# ── Discord (zorunlu) ─────────────────────────────────────────────────────────
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
GUILD_ID=

# ── AI (en az biri zorunlu; Gemini birincil) ────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Analiz kalitesi oncelikli (yavas/pahali): gemini-2.5-pro veya gemini-3.1-pro
# Hizli + iyi (listede varsa): gemini-3.5-flash
# PDF/DOCX fallback ayri — attachment-text icinde flash-lite kullanilir
OPENAI_API_KEY=

# ── FiveM köprüsü (STAGE pull modu + eski slash komutlar) ───────────────────
# FiveM server.cfg ai_vehicle_secret ile AYNI olmali
AI_VEHICLE_SECRET=

# ── STAGE forum kanalı (karakterler) ────────────────────────────────────────
STAGE_FORUM_CHANNEL_ID=

# ── Sunucu / Discord ayarlari ─────────────────────────────────────────────────
SERVER_NAME=Kingpin RP
LOG_CHANNEL_ID=
ADMIN_ROLE_ID=
FORUM_CHANNEL_ID=
STAGE_FORUM_CHANNEL_ID=

# Arsiv konulari icin bot izni yoksa: STAGE_SKIP_ARCHIVED_IMPORT=1
# Eski toplu import modu (varsayilan kapali — /aracal ile on-demand):
# STAGE_BULK_IMPORT=1

# Opsiyonel — PDF/DOCX metin cikarma basarisiz olursa Gemini fallback (0 kapatir)
# STAGE_ATTACHMENT_GEMINI=1

# ── Legacy: bot dogrudan MySQL'e yazarsa (onerilmez, Railway localhost erisemez) ─
# STAGE_DB_HOST=
# STAGE_DB_PORT=3306
# STAGE_DB_USER=
# STAGE_DB_PASS=
# STAGE_DB_NAME=

# FiveM server.cfg:
# set ai_vehicle_bot_url "https://xxx.railway.app"
# set ai_vehicle_secret "AI_VEHICLE_SECRET ile ayni"

# Embed arac gorseli (varsayilan: https://docs.fivem.net/vehicles)
# VEHICLE_IMAGE_BASE_URL=

# Gemini ile gorsel yeniden siralama (false/0 kapatir)
# VEHICLE_VISUAL_ANALYSIS=true
