{
  "name": "kingpin-ai-vehicle-bot",
  "version": "1.0.0",
  "description": "Discord bot — AI destekli RP arac onerisi (Kingpin)",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "node --import tsx --test tests/*.test.ts",
    "register-commands": "tsx src/register-commands.ts",
    "railway:build": "npm run build"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.0",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.7",
    "mammoth": "^1.12.0",
    "openai": "^4.77.0",
    "pdf-parse": "^2.4.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pdf-parse": "^1.1.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
